{
  "compilerOptions": {
    "types": [],
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "commonjs",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "typeRoots": ["./node_modules/@types"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["credentials/**/*", "nodes/**/*", "index.ts"],
  "exclude": ["node_modules", "dist"]
}
